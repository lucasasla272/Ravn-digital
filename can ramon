<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Can Ramon — Tapas y Parrilladas en Barcelona</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Oswald:wght@400;500;600;700&family=Roboto+Slab:wght@300;400;500;600&display=swap" rel="stylesheet">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        :root {
            --color-bg: #1a1410;
            --color-bg-light: #2a2018;
            --color-text: #f5f0e8;
            --color-accent: #c45c3a;
            --color-accent-light: #e07a5f;
            --color-muted: #a89f91;
            --color-card: #251e18;
            --color-gold: #d4a574;
        }

        body {
            font-family: 'Roboto Slab', serif;
            background: var(--color-bg);
            color: var(--color-text);
            line-height: 1.7;
            overflow-x: hidden;
        }

        h1, h2, h3 {
            font-family: 'Oswald', sans-serif;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 2px;
        }

        /* NAV */
        nav {
            position: fixed;
            top: 0;
            width: 100%;
            padding: 1.2rem 2rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
            z-index: 1000;
            background: rgba(26, 20, 16, 0.9);
            backdrop-filter: blur(10px);
            border-bottom: 2px solid var(--color-accent);
        }

        .logo {
            font-family: 'Oswald', sans-serif;
            font-size: 1.5rem;
            font-weight: 700;
            color: var(--color-text);
            letter-spacing: 4px;
            text-transform: uppercase;
        }

        .logo span {
            color: var(--color-accent);
        }

        .nav-links {
            display: flex;
            gap: 2rem;
            list-style: none;
        }

        .nav-links a {
            color: var(--color-text);
            text-decoration: none;
            font-family: 'Oswald', sans-serif;
            font-size: 0.85rem;
            font-weight: 500;
            text-transform: uppercase;
            letter-spacing: 1.5px;
            transition: color 0.3s;
        }

        .nav-links a:hover {
            color: var(--color-accent);
        }

        /* HERO */
        .hero {
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            text-align: center;
            padding: 0 2rem;
            position: relative;
            background: linear-gradient(180deg, rgba(26,20,16,0.4) 0%, rgba(26,20,16,0.9) 100%),
                        url('https://lh3.googleusercontent.com/gps-cs-s/AHRPTWlTn_xE8qJODPfPNeBw_rstXsJbugpJeMQDgQ9lUqG72Ut1TZSPYrwEQPlF4uE4CCKtJvAbp3hToL3zbdq-ab6sVd89VAfX7TVD8yRcACq03o7P78SJ4eBC-5hQVT9pckSv5iQf=w1200-h800-k-no') center/cover;
        }

        .hero-badge {
            background: rgba(196, 92, 58, 0.2);
            border: 2px solid var(--color-accent);
            color: var(--color-accent-light);
            padding: 0.6rem 2rem;
            border-radius: 4px;
            font-family: 'Oswald', sans-serif;
            font-size: 0.85rem;
            text-transform: uppercase;
            letter-spacing: 3px;
            margin-bottom: 2rem;
        }

        .hero h1 {
            font-size: clamp(3.5rem, 8vw, 7rem);
            line-height: 1.0;
            margin-bottom: 1rem;
            letter-spacing: 4px;
        }

        .hero-subtitle {
            font-size: 1.4rem;
            color: var(--color-accent-light);
            font-family: 'Roboto Slab', serif;
            margin-bottom: 1.5rem;
            font-weight: 400;
            letter-spacing: 1px;
        }

        .hero p {
            font-size: 1.1rem;
            color: var(--color-muted);
            max-width: 550px;
            margin-bottom: 2.5rem;
            font-weight: 300;
        }

        .hero-buttons {
            display: flex;
            gap: 1rem;
            flex-wrap: wrap;
            justify-content: center;
        }

        .cta-btn {
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            background: var(--color-accent);
            color: white;
            padding: 1rem 2.5rem;
            border-radius: 4px;
            text-decoration: none;
            font-family: 'Oswald', sans-serif;
            font-weight: 600;
            font-size: 1rem;
            text-transform: uppercase;
            letter-spacing: 1px;
            transition: all 0.3s;
            border: 2px solid var(--color-accent);
        }

        .cta-btn:hover {
            background: transparent;
            color: var(--color-accent);
        }

        .cta-btn.whatsapp {
            background: #25D366;
            border-color: #25D366;
            color: white;
        }

        .cta-btn.whatsapp:hover {
            background: transparent;
            color: #25D366;
        }

        /* SECTIONS */
        section {
            padding: 5rem 2rem;
            max-width: 1100px;
            margin: 0 auto;
        }

        .section-header {
            text-align: center;
            margin-bottom: 3rem;
        }

        .section-header h2 {
            font-size: clamp(2rem, 4vw, 3rem);
            margin-bottom: 0.75rem;
            color: var(--color-text);
        }

        .section-header p {
            color: var(--color-muted);
            font-size: 1rem;
            max-width: 500px;
            margin: 0 auto;
        }

        /* ABOUT */
        .about {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 4rem;
            align-items: center;
        }

        .about-text h2 {
            font-size: 2.5rem;
            margin-bottom: 1.5rem;
            color: var(--color-accent-light);
        }

        .about-text p {
            color: var(--color-muted);
            margin-bottom: 1rem;
            font-size: 1rem;
            line-height: 1.8;
        }

        .about-image {
            position: relative;
            border-radius: 8px;
            overflow: hidden;
            height: 400px;
            border: 3px solid var(--color-accent);
        }

        .about-image img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .about-image::after {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: linear-gradient(180deg, transparent 50%, rgba(26,20,16,0.7) 100%);
        }

        /* REVIEWS */
        .reviews-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
            gap: 1.5rem;
        }

        .review-card {
            background: var(--color-card);
            padding: 2rem;
            border-radius: 8px;
            border: 1px solid rgba(196, 92, 58, 0.2);
            border-left: 4px solid var(--color-accent);
        }

        .review-stars {
            color: var(--color-gold);
            font-size: 1.2rem;
            margin-bottom: 1rem;
            letter-spacing: 2px;
        }

        .review-text {
            color: var(--color-text);
            font-size: 0.95rem;
            line-height: 1.7;
            margin-bottom: 1.5rem;
            font-style: italic;
        }

        .review-author {
            display: flex;
            align-items: center;
            gap: 0.75rem;
        }

        .review-avatar {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            background: var(--color-accent);
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: 'Oswald', sans-serif;
            font-weight: 600;
            color: white;
            font-size: 0.9rem;
        }

        .review-name {
            font-weight: 500;
            font-size: 0.9rem;
            font-family: 'Oswald', sans-serif;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .review-date {
            color: var(--color-muted);
            font-size: 0.8rem;
        }

        /* MENU PREVIEW - 3 secciones */
        .menu-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 2rem;
        }

        .menu-item {
            background: var(--color-card);
            border-radius: 8px;
            overflow: hidden;
            border: 1px solid rgba(196, 92, 58, 0.15);
            transition: all 0.3s;
            border-top: 4px solid var(--color-accent);
        }

        .menu-item:hover {
            transform: translateY(-5px);
            border-color: var(--color-accent);
        }

        .menu-item img {
            width: 100%;
            height: 350px;
            object-fit: cover;
            object-position: top;
        }

        .menu-item .content {
            padding: 1.5rem;
        }

        .menu-item h3 {
            font-size: 1.4rem;
            margin-bottom: 0.5rem;
            color: var(--color-accent-light);
        }

        .menu-item p {
            color: var(--color-muted);
            font-size: 0.9rem;
            margin-bottom: 0.75rem;
        }

        .menu-item .price {
            color: var(--color-gold);
            font-weight: 600;
            font-size: 1.1rem;
            font-family: 'Oswald', sans-serif;
        }

        /* INFO */
        .info-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 2rem;
        }

        .info-card {
            background: var(--color-card);
            padding: 2rem;
            border-radius: 8px;
            text-align: center;
            border: 1px solid rgba(196, 92, 58, 0.15);
            border-bottom: 4px solid var(--color-accent);
        }

        .info-card .icon {
            font-size: 2rem;
            margin-bottom: 1rem;
        }

        .info-card h3 {
            font-size: 1.2rem;
            margin-bottom: 0.5rem;
            color: var(--color-accent-light);
            font-family: 'Oswald', sans-serif;
        }

        .info-card p {
            color: var(--color-muted);
            font-size: 0.9rem;
        }

        /* CTA FINAL */
        .final-cta {
            text-align: center;
            padding: 5rem 2rem;
            background: linear-gradient(180deg, var(--color-bg) 0%, var(--color-bg-light) 100%);
            border-top: 2px solid var(--color-accent);
        }

        .final-cta h2 {
            font-size: clamp(2rem, 4vw, 3rem);
            margin-bottom: 1rem;
            color: var(--color-text);
        }

        .final-cta p {
            color: var(--color-muted);
            margin-bottom: 2rem;
            font-size: 1.1rem;
        }

        /* FOOTER */
        footer {
            text-align: center;
            padding: 2rem;
            color: var(--color-muted);
            font-size: 0.85rem;
            border-top: 1px solid rgba(196, 92, 58, 0.2);
            background: var(--color-bg-light);
        }

        footer a {
            color: var(--color-accent-light);
            text-decoration: none;
        }

        /* RESPONSIVE */
        @media (max-width: 768px) {
            nav {
                padding: 1rem;
            }

            .nav-links {
                display: none;
            }

            .about {
                grid-template-columns: 1fr;
                gap: 2rem;
            }

            .about-image {
                height: 250px;
            }

            .hero-buttons {
                flex-direction: column;
                width: 100%;
                padding: 0 1rem;
            }

            .cta-btn {
                width: 100%;
                justify-content: center;
            }

            .menu-item img {
                height: 280px;
            }
        }
    </style>
