<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Auténtico Pizzeria — Pizza Artesanal en Barcelona</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&family=Lora:ital,wght@0,400;0,500;0,600;1,400&display=swap" rel="stylesheet">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        :root {
            --color-bg: #f8f4e8;
            --color-bg-dark: #e8e0d0;
            --color-text: #2c2416;
            --color-text-light: #5a4d3a;
            --color-accent-green: #2d5a3d;
            --color-accent-red: #c41e3a;
            --color-gold: #c9a96e;
            --color-card: #ffffff;
            --color-border: #d4c8b0;
            --color-img-bg: #f0ebe0;
        }

        body {
            font-family: 'Lora', serif;
            background: var(--color-bg);
            color: var(--color-text);
            line-height: 1.7;
            overflow-x: hidden;
        }

        h1, h2, h3 {
            font-family: 'Poppins', sans-serif;
            font-weight: 600;
        }

        /* NAV */
        nav {
            position: fixed;
            top: 0;
            width: 100%;
            padding: 1.2rem 2rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
            z-index: 1000;
            background: rgba(248, 244, 232, 0.95);
            backdrop-filter: blur(10px);
            border-bottom: 3px solid var(--color-accent-green);
        }

        .logo {
            font-family: 'Poppins', sans-serif;
            font-size: 1.4rem;
            font-weight: 700;
            color: var(--color-accent-red);
            letter-spacing: 1px;
        }

        .logo span {
            color: var(--color-accent-green);
        }

        .nav-links {
            display: flex;
            gap: 2rem;
            list-style: none;
        }

        .nav-links a {
            color: var(--color-text);
            text-decoration: none;
            font-family: 'Poppins', sans-serif;
            font-size: 0.85rem;
            font-weight: 500;
            text-transform: uppercase;
            letter-spacing: 1.5px;
            transition: color 0.3s;
        }

        .nav-links a:hover {
            color: var(--color-accent-red);
        }

        /* HERO */
        .hero {
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            text-align: center;
            padding: 0 2rem;
            position: relative;
            background: linear-gradient(180deg, rgba(248,244,232,0.3) 0%, rgba(248,244,232,0.85) 100%),
                        url('https://lh3.googleusercontent.com/gps-cs-s/AHRPTWkoHXqAj7_VO8gM_kXu8sZYFWF5klydQdq_VZ2BkfM7aqramIuYGNXpl-55B1wP3XHEH4m5nusFNyl3_xFJTu33DbAY97KHCdRUlHLxdvPoed1XSXSO1v8hR8iDqwQLBpgNhfYjKOCF-0B0=w1200-h800-k-no') center/cover;
        }

        .hero-badge {
            background: var(--color-accent-green);
            color: white;
            padding: 0.6rem 2rem;
            border-radius: 50px;
            font-family: 'Poppins', sans-serif;
            font-size: 0.85rem;
            font-weight: 500;
            text-transform: uppercase;
            letter-spacing: 3px;
            margin-bottom: 2rem;
        }

        .hero h1 {
            font-size: clamp(3rem, 7vw, 6rem);
            line-height: 1.0;
            margin-bottom: 1rem;
            letter-spacing: -1px;
            color: var(--color-text);
        }

        .hero-subtitle {
            font-size: 1.4rem;
            color: var(--color-accent-red);
            font-family: 'Lora', serif;
            margin-bottom: 1.5rem;
            font-weight: 500;
            font-style: italic;
        }

        .hero p {
            font-size: 1.1rem;
            color: var(--color-text-light);
            max-width: 550px;
            margin-bottom: 2.5rem;
            font-weight: 400;
        }

        .hero-buttons {
            display: flex;
            gap: 1rem;
            flex-wrap: wrap;
            justify-content: center;
        }

        .cta-btn {
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            background: var(--color-accent-red);
            color: white;
            padding: 1rem 2.5rem;
            border-radius: 50px;
            text-decoration: none;
            font-family: 'Poppins', sans-serif;
            font-weight: 600;
            font-size: 1rem;
            transition: all 0.3s;
            border: 2px solid var(--color-accent-red);
        }

        .cta-btn:hover {
            background: transparent;
            color: var(--color-accent-red);
        }

        .cta-btn.whatsapp {
            background: #25D366;
            border-color: #25D366;
            color: white;
        }

        .cta-btn.whatsapp:hover {
            background: transparent;
            color: #25D366;
        }

        .cta-btn.secondary {
            background: transparent;
            color: var(--color-accent-green);
            border-color: var(--color-accent-green);
        }

        .cta-btn.secondary:hover {
            background: var(--color-accent-green);
            color: white;
        }

        /* SECTIONS */
        section {
            padding: 5rem 2rem;
            max-width: 1100px;
            margin: 0 auto;
        }

        .section-header {
            text-align: center;
            margin-bottom: 3rem;
        }

        .section-header h2 {
            font-size: clamp(2rem, 4vw, 3rem);
            margin-bottom: 0.75rem;
            color: var(--color-text);
        }

        .section-header p {
            color: var(--color-text-light);
            font-size: 1rem;
            max-width: 500px;
            margin: 0 auto;
        }

        /* ABOUT */
        .about {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 4rem;
            align-items: center;
        }

        .about-text h2 {
            font-size: 2.5rem;
            margin-bottom: 1.5rem;
            color: var(--color-accent-green);
        }

        .about-text p {
            color: var(--color-text-light);
            margin-bottom: 1rem;
            font-size: 1rem;
            line-height: 1.8;
        }

        .about-image {
            position: relative;
            border-radius: 16px;
            overflow: hidden;
            height: 400px;
            border: 4px solid var(--color-accent-green);
        }

        .about-image img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .about-image::after {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: linear-gradient(180deg, transparent 50%, rgba(248,244,232,0.7) 100%);
        }

        /* REVIEWS */
        .reviews-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
            gap: 1.5rem;
        }

        .review-card {
            background: var(--color-card);
            padding: 2rem;
            border-radius: 16px;
            border: 1px solid var(--color-border);
            border-left: 4px solid var(--color-accent-red);
            box-shadow: 0 4px 20px rgba(0,0,0,0.05);
        }

        .review-stars {
            color: var(--color-gold);
            font-size: 1.2rem;
            margin-bottom: 1rem;
            letter-spacing: 2px;
        }

        .review-text {
            color: var(--color-text);
            font-size: 0.95rem;
            line-height: 1.7;
            margin-bottom: 1.5rem;
            font-style: italic;
        }

        .review-author {
            display: flex;
            align-items: center;
            gap: 0.75rem;
        }

        .review-avatar {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            background: var(--color-accent-green);
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: 'Poppins', sans-serif;
            font-weight: 600;
            color: white;
            font-size: 0.9rem;
        }

        .review-name {
            font-weight: 500;
            font-size: 0.9rem;
            font-family: 'Poppins', sans-serif;
        }

        .review-date {
            color: var(--color-text-light);
            font-size: 0.8rem;
        }

        /* MENU PREVIEW */
        .menu-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 2rem;
        }

        .menu-item {
            background: var(--color-card);
            border-radius: 16px;
            overflow: hidden;
            border: 1px solid var(--color-border);
            transition: all 0.3s;
            box-shadow: 0 4px 20px rgba(0,0,0,0.05);
            border-top: 4px solid var(--color-accent-red);
        }

        .menu-item:hover {
            transform: translateY(-5px);
            box-shadow: 0 8px 30px rgba(0,0,0,0.1);
        }

        .menu-item .img-container {
            width: 100%;
            height: 420px;
            background: var(--color-img-bg);
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
            padding: 1rem;
        }

        .menu-item .img-container img {
            max-width: 100%;
            max-height: 100%;
            object-fit: contain;
            border-radius: 8px;
        }

        .menu-item .content {
            padding: 1.5rem;
        }

        .menu-item h3 {
            font-size: 1.4rem;
            margin-bottom: 0.5rem;
            color: var(--color-accent-green);
        }

        .menu-item p {
            color: var(--color-text-light);
            font-size: 0.9rem;
            margin-bottom: 0.75rem;
        }

        .menu-item .price {
            color: var(--color-accent-red);
            font-weight: 600;
            font-size: 1.1rem;
            font-family: 'Poppins', sans-serif;
        }

        /* INFO */
        .info-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 2rem;
        }

        .info-card {
            background: var(--color-card);
            padding: 2rem;
            border-radius: 16px;
            text-align: center;
            border: 1px solid var(--color-border);
            border-bottom: 4px solid var(--color-accent-green);
            box-shadow: 0 4px 20px rgba(0,0,0,0.05);
        }

        .info-card .icon {
            font-size: 2rem;
            margin-bottom: 1rem;
        }

        .info-card h3 {
            font-size: 1.2rem;
            margin-bottom: 0.5rem;
            color: var(--color-accent-green);
            font-family: 'Poppins', sans-serif;
        }

        .info-card p {
            color: var(--color-text-light);
            font-size: 0.9rem;
        }

        /* CTA FINAL */
        .final-cta {
            text-align: center;
            padding: 5rem 2rem;
            background: linear-gradient(180deg, var(--color-bg) 0%, var(--color-bg-dark) 100%);
            border-top: 3px solid var(--color-accent-red);
        }

        .final-cta h2 {
            font-size: clamp(2rem, 4vw, 3rem);
            margin-bottom: 1rem;
            color: var(--color-text);
        }

        .final-cta p {
            color: var(--color-text-light);
            margin-bottom: 2rem;
            font-size: 1.1rem;
        }

        /* FOOTER */
        footer {
            text-align: center;
            padding: 2rem;
            color: var(--color-text-light);
            font-size: 0.85rem;
            border-top: 1px solid var(--color-border);
            background: var(--color-bg-dark);
        }

        footer a {
            color: var(--color-accent-red);
            text-decoration: none;
        }

        /* RESPONSIVE */
        @media (max-width: 768px) {
            nav {
                padding: 1rem;
            }

            .nav-links {
                display: none;
            }

            .about {
                grid-template-columns: 1fr;
                gap: 2rem;
            }

            .about-image {
                height: 250px;
            }

            .hero-buttons {
                flex-direction: column;
                width: 100%;
                padding: 0 1rem;
            }

            .cta-btn {
                width: 100%;
                justify-content: center;
            }

            .menu-item .img-container {
                height: 350px;
            }
        }
    </style>
